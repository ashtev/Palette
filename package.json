{
  "name": "palette",
  "version": "1.0.0",
  "description": "Brand color palette builder and optimizer",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node --watch server.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm --prefix client install && npm --prefix client run build",
    "preview": "npm --prefix client run preview"
  },
  "dependencies": {
    "chroma-js": "^3.1.2",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
